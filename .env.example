# Copy to .env and fill in values. Do not commit the real .env.

FLASK_SECRET_KEY=change-me-generate-with-python-secrets-token_hex-32
CORS_ORIGINS=http://localhost:3000,https://your.domain

ADMIN_USERNAME=admin
ADMIN_PASSWORD=

LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15

APEX_TLS_VERIFY=1

# --- Phase 1 (public launch) -------------------------------------------------
# Set to "true" once invite gating is dropped for general availability.
REGISTRATION_OPEN=false

# Transactional email via Brevo (https://www.brevo.com/). Leave empty in dev —
# the backend falls back to a NullEmailSender that logs payloads to /tmp/lt-mail/.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@krranalyser.fr
BREVO_SENDER_NAME=LT-Analyzer

# Base URL of the Next.js frontend, used to build verify/reset links in emails.
FRONTEND_BASE_URL=https://kart.krranalyser.fr

# Cloudflare Turnstile secret. Empty = soft-pass with a warning (only OK in dev).
TURNSTILE_SECRET_KEY=

# Force httpOnly secure session cookie. Set to "false" only on http://localhost dev.
SESSION_COOKIE_SECURE=true

# In production, leave false — the admin-only test/simulate-session/* endpoints
# don't get registered, so they 404.
ENABLE_TEST_ENDPOINTS=false

# Verification & password-reset token TTLs.
VERIFICATION_TOKEN_HOURS=48
RESET_TOKEN_HOURS=1

# Rate limits — per-hour caps. Tighten only if abuse signals appear.
RATE_LIMIT_REGISTER_IP_PER_HOUR=5
RATE_LIMIT_FORGOT_IP_PER_HOUR=10
RATE_LIMIT_FORGOT_EMAIL_PER_HOUR=3
RATE_LIMIT_VERIFY_IP_PER_HOUR=30
RATE_LIMIT_RESEND_IP_PER_HOUR=5
RATE_LIMIT_RESEND_EMAIL_PER_HOUR=3
